{
  "version": 2,
  "buildCommand": "npm install --legacy-peer-deps",
  "devCommand": "node server.js",
  "installCommand": "npm install --legacy-peer-deps",
  "public": true,
  "functions": {
    "api/handler.js": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/handler.js"
    },
    {
      "src": "/send",
      "dest": "api/handler.js"
    },
    {
      "src": "/login",
      "dest": "api/handler.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "api/handler.js"
    },
    {
      "src": "/(.*)",
      "dest": "public/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/public/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600"
        }
      ]
    }
  ]
}
