{
  "version": 2,
  "buildCommand": "npm install",
  "devCommand": "node server.js",
  "installCommand": "npm install",
  "public": "public",
  "functions": {
    "api/handler.js": {
      "runtime": "nodejs18.x",
      "memory": 1024
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/handler.js"
    },
    {
      "src": "/public/(.*)",
      "dest": "public/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
