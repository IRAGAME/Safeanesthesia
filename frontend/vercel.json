{
  "version": 2,
  "routes": [
    {
      "src": "/\\..*",
      "status": 404
    },
    {
      "src": "/(.*)\\.html$",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "/(about|formations|formation|contact|admin|login)$",
      "dest": "/$1.html"
    }
  ]
}
