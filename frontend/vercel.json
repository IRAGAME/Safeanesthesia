{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    {
      "src": "/\\..*",
      "status": 404
    },
    {
      "src": "/(.*)\\.html$",
      "headers": {
        "Cache-Control": "public, max-age=3600"
      }
    },
    {
      "src": "/(?!.*\\.[^/]+$).*",
      "dest": "/index.html"
    }
  ]
}

